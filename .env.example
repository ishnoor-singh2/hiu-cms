# Sanity Project Configuration
# Get these values from your Sanity project dashboard at https://manage.sanity.io

# Your Sanity project ID
SANITY_STUDIO_PROJECT_ID=your-project-id-here

# Your Sanity dataset
SANITY_STUDIO_DATASET=production

# API token (keep this secret in production)
# Generate a new token: https://manage.sanity.io/account/tokens
SANITY_API_TOKEN=your-api-token-here

# Frontend API
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id-here
NEXT_PUBLIC_SANITY_DATASET=production
